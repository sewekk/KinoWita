{% extends 'base.html.twig' %}

{% block title %}Logowanie — KinoWita{% endblock %}

{% block body %}
<div class="max-w-md mx-auto my-12">
    
    <div class="text-center mb-8 border-b-2 border-stone-900 pb-6">
        <h1 class="section-header">Logowanie</h1>
        <p class="text-stone-500 font-mono text-xs uppercase tracking-wider mt-1">
            Zaloguj się do swojego konta systemowego
        </p>
    </div>

    <div class="b-card">
        {% if error %}
            <div class="p-4 mb-6 text-xs font-mono border-2 bg-red-50 border-red-900 text-red-900 font-bold uppercase">
                [BŁĄD]: {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="space-y-6">
            <div>
                <label for="inputEmail" class="form-label">Adres e-mail</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-input" autocomplete="email" required autofocus>
            </div>

            <div>
                <label for="inputPassword" class="form-label">Hasło</label>
                <input type="password" name="password" id="inputPassword" class="form-input" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="flex items-center">
                <input type="checkbox" name="_remember_me" id="remember_me" class="w-4 h-4 text-stone-900 bg-stone-50 border-2 border-stone-900 accent-stone-900 focus:ring-0">
                <label for="remember_me" class="ml-2 text-xs font-mono font-bold uppercase tracking-wider text-stone-600 select-none">Zapamiętaj mnie</label>
            </div>

            <button type="submit" class="w-full btn-primary">
                Zaloguj się &rarr;
            </button>
        </form>
    </div>

    <p class="text-center mt-6">
        <a href="{{ path('app_home') }}" class="text-xs font-mono font-bold uppercase tracking-wider text-stone-500 hover:text-stone-900 transition-colors">
            &larr; Powrót do serwisu
        </a>
    </p>
</div>
{% endblock %}