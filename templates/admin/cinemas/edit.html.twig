{% extends 'base.html.twig' %}

{% block title %}Edytuj placówkę — Admin{% endblock %}

{% block body %}
<div class="border-b-2 border-stone-900 pb-6 mb-8">
    <h1 class="section-header">Edytuj placówkę kina</h1>
    <p class="text-stone-500 font-mono text-xs uppercase tracking-wider mt-1">
        {{ cinema.name }}
    </p>
</div>

<div class="b-card max-w-2xl">
    {{ form_start(form) }}

        <div class="space-y-5">
            <div>
                {{ form_label(form.name, null, {
                    label_attr: {
                        class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                    }
                }) }}
                {{ form_widget(form.name, {
                    attr: {
                        class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm'
                    }
                }) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                {{ form_label(form.city, null, {
                    label_attr: {
                        class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                    }
                }) }}
                {{ form_widget(form.city, {
                    attr: {
                        class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm'
                    }
                }) }}
                {{ form_errors(form.city) }}
            </div>

            <div>
                {{ form_label(form.address, null, {
                    label_attr: {
                        class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                    }
                }) }}
                {{ form_widget(form.address, {
                    attr: {
                        class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm'
                    }
                }) }}
                {{ form_errors(form.address) }}
            </div>

            <div>
                {{ form_label(form.openingHours, null, {
                    label_attr: {
                        class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                    }
                }) }}
                {{ form_widget(form.openingHours, {
                    attr: {
                        class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm',
                        placeholder: 'np. 10:00 - 22:00'
                    }
                }) }}
                {{ form_errors(form.openingHours) }}
            </div>
        </div>

        <div class="flex items-center gap-3 mt-8">
            <button type="submit" class="btn-primary">
                Zapisz zmiany
            </button>

            <a href="{{ path('app_admin_cinemas') }}" class="btn-secondary">
                Anuluj
            </a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}