{% extends 'base.html.twig' %}

{% block title %}Sale — Panel Pracownika{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto my-6">

    <div class="border-b-2 border-stone-900 pb-6 mb-8 flex items-end justify-between">
        <div>
            <h1 class="section-header">Sale kinowe</h1>
            <p class="text-stone-500 font-mono text-xs uppercase tracking-wider mt-1">
                Placówka: <span class="font-bold text-stone-900">{{ cinema.name }}</span>
            </p>
        </div>

        <a href="{{ path('app_staff_halls_new') }}" class="btn-primary">
            + Dodaj salę
        </a>
    </div>

    {% if halls is empty %}
        <div class="b-card text-center py-12 text-stone-400 font-mono text-sm">
            Brak sal w tej placówce.
        </div>
    {% else %}
        <div class="b-card p-0 overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b-2 border-stone-900 bg-stone-50">
                        <th class="text-left px-6 py-3 font-mono text-xs uppercase tracking-widest text-stone-500">ID</th>
                        <th class="text-left px-6 py-3 font-mono text-xs uppercase tracking-widest text-stone-500">Nazwa sali</th>
                        <th class="text-left px-6 py-3 font-mono text-xs uppercase tracking-widest text-stone-500">Rzędy</th>
                        <th class="text-left px-6 py-3 font-mono text-xs uppercase tracking-widest text-stone-500">Miejsca w rzędzie</th>
                        <th class="text-left px-6 py-3 font-mono text-xs uppercase tracking-widest text-stone-500">Łącznie miejsc</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for hall in halls %}
                        <tr class="border-b border-stone-200 hover:bg-stone-50 transition-colors">
                            <td class="px-6 py-4 font-mono text-xs text-stone-400">#{{ hall.id }}</td>
                            <td class="px-6 py-4 font-semibold">{{ hall.name }}</td>
                            <td class="px-6 py-4 font-mono text-xs">{{ hall.rowsCount }}</td>
                            <td class="px-6 py-4 font-mono text-xs">{{ hall.seatsPerRow }}</td>
                            <td class="px-6 py-4 font-mono text-xs font-bold">
                                {{ hall.rowsCount * hall.seatsPerRow }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-3">
                                    <a href="{{ path('app_staff_halls_edit', {id: hall.id}) }}" class="btn-secondary !py-1 !px-3 text-xs">
                                        Edytuj
                                    </a>

                                    <form method="post" action="{{ path('app_staff_halls_delete', {id: hall.id}) }}" onsubmit="return confirm('Czy na pewno chcesz usunąć tę salę?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_hall_' ~ hall.id) }}">

                                        <button type="submit" class="text-xs font-mono font-bold uppercase text-red-700 hover:text-red-900 transition-colors">
                                            Usuń
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <div class="mt-6">
        <a href="{{ path('app_staff_dashboard') }}" class="btn-secondary">
            Wróć do panelu
        </a>
    </div>

</div>
{% endblock %}