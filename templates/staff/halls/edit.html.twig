{% extends 'base.html.twig' %}

{% block title %}Edytuj salę — Panel Pracownika{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto my-6">

    <div class="border-b-2 border-stone-900 pb-6 mb-8">
        <h1 class="section-header">Edytuj salę</h1>
        <p class="text-stone-500 font-mono text-xs uppercase tracking-wider mt-1">
            {{ hall.name }} — {{ cinema.name }}
        </p>
    </div>

    <div class="b-card max-w-2xl">
        {{ form_start(form) }}

            <div class="space-y-5">
                <div>
                    {{ form_label(form.name, null, {
                        label_attr: {
                            class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                        }
                    }) }}
                    {{ form_widget(form.name, {
                        attr: {
                            class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm'
                        }
                    }) }}
                    {{ form_errors(form.name) }}
                </div>

                <div>
                    {{ form_label(form.rowsCount, null, {
                        label_attr: {
                            class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                        }
                    }) }}
                    {{ form_widget(form.rowsCount, {
                        attr: {
                            class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm',
                            min: 1
                        }
                    }) }}
                    {{ form_errors(form.rowsCount) }}
                </div>

                <div>
                    {{ form_label(form.seatsPerRow, null, {
                        label_attr: {
                            class: 'block font-mono text-xs uppercase tracking-widest text-stone-500 mb-2'
                        }
                    }) }}
                    {{ form_widget(form.seatsPerRow, {
                        attr: {
                            class: 'w-full border-2 border-stone-900 px-4 py-2 text-sm',
                            min: 1
                        }
                    }) }}
                    {{ form_errors(form.seatsPerRow) }}
                </div>
            </div>

            <div class="flex items-center gap-3 mt-8">
                <button type="submit" class="btn-primary">
                    Zapisz zmiany
                </button>

                <a href="{{ path('app_staff_halls') }}" class="btn-secondary">
                    Anuluj
                </a>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}